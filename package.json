{
  "name": "crm-followup-module",
  "version": "1.0.0",
  "description": "CRM客户事件跟进模块 - 跨境物流云服务",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "server:py": "python server/app.py",
    "server:node": "node server/index.js",
    "start:py": "concurrently \"npm run server:py\" \"npm run dev\"",
    "start:node": "concurrently \"npm run server:node\" \"npm run dev\""
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "dayjs": "^1.11.10",
    "react-quill": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.0",
    "concurrently": "^8.2.2"
  }
}